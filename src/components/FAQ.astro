---
interface Props { items: { q: string; a: string }[]; }
const { items } = Astro.props;
---
<div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
  <div class="px-6 py-4 border-b border-slate-100">
    <h2 class="text-base font-bold text-navy-900">Frequently Asked Questions</h2>
  </div>
  <div class="divide-y divide-slate-100">
    {items.map((item, i) => (
      <details class="group" open={i === 0}>
        <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none">
          <span class="font-semibold text-sm text-navy-900 pr-4">{item.q}</span>
          <svg class="w-4 h-4 text-slate-400 flex-shrink-0 transition-transform group-open:rotate-180"
               viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <div class="px-6 pb-4 text-sm text-slate-600 leading-relaxed">{item.a}</div>
      </details>
    ))}
  </div>
</div>
