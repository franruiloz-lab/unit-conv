---
const converters = [
  { label: 'Length Converter', href: '/length-converter/' },
  { label: 'Weight Converter', href: '/weight-converter/' },
  { label: 'Temperature Converter', href: '/temperature-converter/' },
  { label: 'Area Converter', href: '/area-converter/' },
  { label: 'Volume Converter', href: '/volume-converter/' },
  { label: 'Speed Converter', href: '/speed-converter/' },
  { label: 'Data Storage Converter', href: '/data-storage-converter/' },
  { label: 'Time Converter', href: '/time-converter/' },
  { label: '5 Meters to Feet', href: '/length/5-meters-to-feet/' },
  { label: '100 kg to lbs', href: '/weight/100-kg-to-lbs/' },
];
---

<footer class="bg-navy-900 text-slate-400 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 bg-brand-600 rounded-lg flex items-center justify-center">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
            </svg>
          </div>
          <span class="text-white font-extrabold text-base">Unit<span class="text-brand-400">Calc</span></span>
        </a>
        <p class="text-sm leading-relaxed">
          Free unit conversion calculators. Instantly convert length, weight, temperature, area, volume, speed and more.
        </p>
      </div>

      <!-- Converters -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Popular Converters</h3>
        <ul class="space-y-2">
          {converters.map(t => (
            <li>
              <a href={t.href} class="text-sm hover:text-brand-400 transition-colors">{t.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- About -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3">About</h3>
        <p class="text-sm leading-relaxed mb-3">
          UnitCalc provides accurate, fast unit conversions. All calculations run in your browser — no data is sent to any server.
        </p>
        <p class="text-xs text-slate-500">
          Results are based on standard international conversion factors. Always verify critical measurements with official sources.
        </p>
      </div>
    </div>

    <div class="border-t border-navy-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-slate-500">&copy; {new Date().getFullYear()} UnitCalc. All rights reserved.</p>
      <div class="flex gap-4 text-xs">
        <a href="/privacy/" class="hover:text-brand-400 transition-colors">Privacy Policy</a>
        <a href="/terms/" class="hover:text-brand-400 transition-colors">Terms</a>
        <a href="/cookie-policy/" class="hover:text-brand-400 transition-colors">Cookie Policy</a>
        <a href="/#converters" class="hover:text-brand-400 transition-colors">All Converters</a>
      </div>
    </div>
  </div>
</footer>
